        <mxCell id="-eXX5pEjAnPX1VIMQY5w-1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;dashed=1;dashPattern=8 4 1 4;strokeColor=#FF0000;align=left;verticalAlign=top;" value="&lt;div&gt;Sensor smoothing library&lt;br&gt;&lt;span style=&quot;color: rgba(0, 0, 0, 0); font-family: monospace; font-size: 0px; text-wrap-mode: nowrap;&quot;&gt;%3CmxGraphModel%3E%3Croot%3E%3CmxCell%20id%3D%220%22%2F%3E%3CmxCell%20id%3D%221%22%20parent%3D%220%22%2F%3E%3CmxCell%20id%3D%222%22%20parent%3D%221%22%20style%3D%22rounded%3D0%3BwhiteSpace%3Dwrap%3Bhtml%3D1%3BfillColor%3Dnone%3Bdashed%3D1%3BdashPattern%3D8%204%201%204%3BstrokeColor%3D%23FF0000%3Balign%3Dleft%3BverticalAlign%3Dtop%3B%22%20value%3D%221.%20What%20is%20SSI%3F%20What%20is%20the%20main%20difference%20between%20it%20and%20ABZ%3F%26lt%3Bdiv%26gt%3B2.%20What%20is%20the%20output%20of%20our%20ADC%3F%26lt%3B%2Fdiv%26gt%3B%26lt%3Bdiv%26gt%3B3.%20How%20many%20shunt%20resistors%20for%20the%20phases%3F%20How%20do%20we%20choose%20a%20resistance%20value%3F%20FOC%3F%20Low%20side%20current%20sensing%3F%20ISSUE%3A%20For%20SimpleFOC%2C%20we%20need%20to%20know%20all%203%20current%20phases%2C%20TMC6300%20is%20weird%20as%20it%20bridges%20current%20for%20U%20and%20V%2C%20not%20allowing%20us%20to%20separate%20them.%20Soln%3A%20Inline%20current%20sensing%20instead%3F%26lt%3B%2Fdiv%26gt%3B%26lt%3Bdiv%26gt%3B4.%20Is%20there%20enough%20current%20budget%3F%20Is%20there%20enough%20torque%20output%3F%20What%20would%20be%20the%20ADC%20range%3F%26lt%3B%2Fdiv%26gt%3B%26lt%3Bdiv%26gt%3B5.%20Can%20we%20justly%20run%20the%20motor%20at%209V%3F%20What%20can%20we%20do%20to%20step%20the%20voltage%20down%3F%26lt%3B%2Fdiv%26gt%3B%26lt%3Bdiv%26gt%3B%26lt%3Bbr%26gt%3B%26lt%3B%2Fdiv%26gt%3B%26lt%3Bdiv%26gt%3BGrounding%20in%20current%20sense%20amplifiers%26lt%3Bbr%26gt%3Bhttps%3A%2F%2Fwww.ti.com%2Flit%2Fan%2Fsboa536%2Fsboa536.pdf%3Fts%3D1662480209644%26amp%3Bamp%3Bref_url%3Dhttps%25253A%25252F%25252Fwww.ti.com%25252Fproduct%25252FINA240%26lt%3B%2Fdiv%26gt%3B%26lt%3Bdiv%26gt%3B%26lt%3Bbr%26gt%3B%26lt%3B%2Fdiv%26gt%3B%26lt%3Bdiv%26gt%3BFilter%20ADC%20inputs%20w%2F%20low%20pass%26lt%3B%2Fdiv%26gt%3B%26lt%3Bdiv%26gt%3Bhttps%3A%2F%2Fwww.analog.com%2Fen%2Fresources%2Fanalog-dialogue%2Farticles%2Fpractical-filter-design-precision-adcs.html%26lt%3B%2Fdiv%26gt%3B%26lt%3Bdiv%26gt%3B-%20To%20prevent%20aliasing%3A%20filter%20out%20frequencies%20%26amp%3Bgt%3B%3D%20sample%20frequency%20%2F%202%26lt%3B%2Fdiv%26gt%3B%26lt%3Bdiv%26gt%3Bhttps%3A%2F%2Fwww.youtube.com%2Fwatch%3Fv%3D5SMsRApsrQQ%26lt%3B%2Fdiv%26gt%3B%26lt%3Bdiv%26gt%3B%26lt%3Bbr%26gt%3B%26lt%3B%2Fdiv%26gt%3B%26lt%3Bdiv%26gt%3B%26lt%3Bbr%26gt%3B%26lt%3B%2Fdiv%26gt%3B%26lt%3Bdiv%26gt%3B%26lt%3Bbr%26gt%3B%26lt%3B%2Fdiv%26gt%3B%22%20vertex%3D%221%22%3E%3CmxGeometry%20height%3D%22263.5%22%20width%3D%22525%22%20x%3D%22-845%22%20y%3D%22551.5%22%20as%3D%22geometry%22%2F%3E%3C%2FmxCell%3E%3C%2Froot%3E%3C%2FmxGraphModel%3E&lt;/span&gt;&lt;/div&gt;&lt;div&gt;https://github.com/simplefoc/Arduino-FOC-drivers/blob/master/src/encoders/smoothing/SmoothingSensor.cpp&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
