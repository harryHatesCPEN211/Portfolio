        <mxCell id="rIV6RPVdMHWxdZFjyPGH-136" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;" value="&lt;b&gt;Data Written By:&lt;/b&gt;&lt;div&gt;MotorControlTask (heartbeat), TelemetryTask (heartbeat), WatchdogTask (faults)&amp;nbsp; &amp;nbsp; &amp;nbsp; &amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Source of Data:&amp;nbsp;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;Task loop timestamps + fault detection logic&amp;nbsp; &amp;nbsp;&amp;nbsp;&amp;nbsp;&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;Read By:&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&amp;nbsp;WatchdogTask (monitors heartbeats), all tasks (check fault_latched / control_enabled before acting)&amp;nbsp;&lt;/div&gt;" vertex="1">
          <mxGeometry height="220" width="320" x="-597.44" y="2505" as="geometry" />
        </mxCell>
        <mxCell id="rIV6RPVdMHWxdZFjyPGH-137" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;div&gt;&lt;font size=&quot;1&quot;&gt;Parse incoming serial commands&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;1&quot;&gt;G:&amp;lt;gain&amp;gt; | PID:P,I,D,P,I,D&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;1&quot;&gt;• Update RuntimeConfig -&amp;gt; SharedState&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;1&quot;&gt;• Stream telemetry over USB-CDC&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;1&quot;&gt;• Update telemetry heartbeat&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="335" width="430" x="2390" y="1171" as="geometry" />
        </mxCell>
        <mxCell id="rIV6RPVdMHWxdZFjyPGH-138" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;div&gt;&lt;font size=&quot;1&quot;&gt;• Monitor control heartbeat freshness&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;1&quot;&gt;• Detect stale sensor / command data&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;1&quot;&gt;• Latch fault flags in SystemState&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;font size=&quot;1&quot;&gt;• Call stopMotor() on fault&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="180" width="290" x="2460" y="2388" as="geometry" />
